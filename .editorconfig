root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{c,h,asm,s,S}]
indent_style = space
indent_size = 4

[*.{rs}]
indent_style = space
indent_size = 4

[*.{py}]
indent_style = space
indent_size = 4

[*.{yaml,yml,toml}]
indent_style = space
indent_size = 2

[*.{json}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab

[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false
